{
  "name": "al-infaaq",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "db:down": "node ./scripts/with-workspace-env.mjs docker compose down",
    "db:generate": "node ./scripts/with-workspace-env.mjs bun run --cwd packages/db db:generate",
    "db:logs": "node ./scripts/with-workspace-env.mjs docker compose logs -f postgres",
    "db:migrate": "node ./scripts/with-workspace-env.mjs bun run --cwd packages/db db:migrate",
    "db:migrate:deploy": "node ./scripts/with-workspace-env.mjs bun run --cwd packages/db db:migrate:deploy",
    "db:studio": "node ./scripts/with-workspace-env.mjs bun run --cwd packages/db db:studio",
    "db:up": "node ./scripts/with-workspace-env.mjs docker compose up -d postgres",
    "dev": "turbo dev --parallel",
    "dev:api": "turbo dev --filter=@al-infaaq/api",
    "dev:web": "turbo dev --filter=@al-infaaq/web",
    "format": "biome format --write .",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@types/bun": "^1.3.14",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}
